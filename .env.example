SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/<db>?sslmode=require&channel_binding=require
SPRING_DATASOURCE_USERNAME=<username>
SPRING_DATASOURCE_PASSWORD=<password>

SERVER_PORT=8080

JWT_SECRET_KEY=secret_key

APP_BOOKS_SEED_ON_EMPTY=true
APP_BOOKS_SEED_FILE=books.json
APP_BOOKS_MAX_RESULTS_PER_QUERY=1
APP_BOOKS_REQUEST_DELAY_MS=150
APP_BOOKS_MAX_ATTEMPTS=3
APP_BOOKS_RETRY_BACKOFF_MS=600
GOOGLE_BOOKS_API_KEY=
